NODE_ENV=development
DEMO_MODE=true
PORT=8787
CLIENT_ORIGIN=http://localhost:5180
OAUTH_CALLBACK_BASE=http://localhost:8787
DATABASE_FILE=./data/debut.db
SESSION_SECRET=replace-me-in-live
COOLIFY_BASE_URL=https://coolify.yourdomain.com
COOLIFY_API_TOKEN=your-team-scoped-bearer-token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_EMAILS=you@example.com
ALLOWED_ORIGINS=http://localhost:5180
# Business email hosting (mailcow). Unset → the Email section renders but mailbox
# management is disabled (reads empty, writes 503).
MAILCOW_API_URL=https://mail.debutdepoly.com
MAILCOW_API_KEY=
MAIL_HOSTNAME=mail.debutdepoly.com
MAIL_WEBMAIL=mail.debutdepoly.com
# Hostname that serves the public status page at its root (add it as a domain on
# the panel's Coolify app so Traefik routes + certs it here). Default shown.
STATUS_HOSTNAME=status.debutdepoly.com

# --- Billing (subsystem C: Stripe + prepaid credit wallet) ---
# Test mode first: sk_test_… / whsec_…. Live is a key swap, not a code change.
# Env-only — never store these in the DB. The webhook secret comes from either
# `stripe listen --forward-to localhost:8787/api/stripe/webhook` (prints whsec_…)
# or Dashboard → Developers → Webhooks. Test key + live webhook secret (or vice
# versa) 400s every webhook and silently fails to credit wallets — keep them paired.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: override the USD→GBP conversion at runtime via app_settings key
# 'usd_gbp_rate' (default 0.79); no env var — set it through the DB/settings.
